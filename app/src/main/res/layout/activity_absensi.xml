<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary"
        android:paddingStart="4dp"
        android:paddingEnd="20dp"
        android:paddingVertical="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/btnBack"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Absensi"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClockIn"
                android:text="Clock In"
                android:textAllCaps="false"
                android:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/corner_radius_sm"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClockOut"
                android:text="Clock Out"
                android:textAllCaps="false"
                android:textColor="@color/status_rejected"
                app:strokeColor="@color/status_rejected"
                app:cornerRadius="@dimen/corner_radius_sm"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height" />
        </LinearLayout>

        <TextView
            android:text="Riwayat Presensi"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRiwayat"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_md"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>