<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="@dimen/corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="@dimen/card_stroke_width"
    app:strokeColor="@color/stroke_light"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvJenis"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvStatus"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_status_pill"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDetail"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvKaryawan"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvKomentarAtasan"
            android:textSize="12sp"
            android:textColor="@color/status_rejected"
            android:textStyle="italic"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/layoutAksi"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTolak"
                android:text="Tolak"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/status_rejected"
                app:strokeColor="@color/status_rejected"
                app:cornerRadius="@dimen/corner_radius_sm"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetuju"
                android:text="Setuju"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:backgroundTint="@color/status_approved"
                app:cornerRadius="@dimen/corner_radius_sm"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>