<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fillViewport="true"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/primary"
            android:paddingStart="4dp"
            android:paddingEnd="20dp"
            android:paddingVertical="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnBack"
                android:text="←"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:text="Ajukan Cuti"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            app:cardCornerRadius="@dimen/corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="@dimen/card_stroke_width"
            app:strokeColor="@color/stroke_light"
            android:layout_margin="@dimen/spacing_md"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSisaJatah"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="Jenis Cuti"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <Spinner
                    android:id="@+id/spinnerJenis"
                    android:background="@drawable/bg_status_pill_outline"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Info otomatis (Melahirkan / Duka) -->
                <TextView
                    android:id="@+id/tvInfoOtomatis"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:background="@color/icon_bg_blue"
                    android:padding="12dp"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- Jumlah hari (Tahunan / Sakit / Lainnya) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutJumlahHari"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etJumlahHari"
                        android:hint="Jumlah hari"
                        android:inputType="number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Keterangan (Lainnya) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutKeterangan"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etKeterangan"
                        android:hint="Keterangan cuti"
                        android:minLines="2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <CheckBox
                    android:id="@+id/cbKasusKhusus"
                    android:text="Kasus khusus / urgent (tidak potong jatah cuti)"
                    android:textSize="13sp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAjukan"
                    android:text="Ajukan Cuti"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/primary"
                    app:cornerRadius="@dimen/corner_radius_sm"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>